#!/usr/bin/env sh

set -e
set -u

LOG_PREFIX="systemd-boot-btrfs"
err() {
    bug_report="If you think an error has occurred, please file a bug report at \"https://github.com/okmans/systemd-boot-btrfs\""
    printf "%s: Error: %s %s\n" "$LOG_PREFIX" "$*" "${bug_report}" >&2
    exit 1
}

BOOT_DIR="/boot"

initramfs_img="$(find "${BOOT_DIR}" -maxdepth 1 -type f \
    \( -name 'initrd*' -o -name 'initramfs*' \) -print -quit)"
[ ! -e "${initramfs_img}" ] && err "no initramfs image was found."

# Check if systemd-boot is the default bootloader
systemd_boot_efi="$(find "${BOOT_DIR}" -type f \
    -name 'systemd*.efi' -print -quit)"
[ ! -e "${systemd_boot_efi}" ] && \
    err "systemd-boot is not the default bootloader."

# Check if systemd loader entries directory exists
entries_dir="$(find "${BOOT_DIR}" -type d \
    -path '*/loader/entries' -print -quit)"
[ ! -d "${entries_dir}" ] && err "systemd entries directory does not exist."

# Find out a template config 'main*.conf' or the old lead config
base_conf="$(find "${entries_dir}" -maxdepth 1 -type f \
    -name 'main-*.conf' -print -quit)"
[ ! -e "${base_conf}" ] && \
    base_conf="$(find "${entries_dir}" -maxdepth 1 -type f \
        -name '*.conf' \
        -printf '%T@ %f\n' \
        | sort -n | head -1 | awk '{print $NF}')"

[ -z "${base_conf}" ] && \
    err "could not find main-*.conf or the old lead config."

#if ! grep -q -i -e 'rootflags=' "${entries_dir}/${base_conf}" ; then
#    printf "your main boot entry file missing the option 'rootflags'.\n"
#    exit 1
#fi

boot_snapshot_name="${base_conf%.conf}"
boot_snapshot_suffix="snap.conf"

# Remove existent snapshot entries
find "${entries_dir}" -maxdepth 1 -type f \
    -name "${boot_snapshot_name}*-${boot_snapshot_suffix}" -delete

SNAPSHOTS_DIR="/.snapshots"
get_btrfs_snapshots() {
    btrfs subvolume list -s -o "${SNAPSHOTS_DIR}" | awk '{print $NF}'
}

snapper_info="info.xml"
make_conf() {
    snapshot_subvol="$1"
    snapshot_num="$(printf "%s\n" "${snapshot_subvol}" | sed -E -e 's|.*\/([0-9]+)\/.*|\1|')"
    snapshot_info="$(find "${SNAPSHOTS_DIR}" -maxdepth 2 -type f -path "*/${snapshot_num}/${snapper_info}" -print -quit)"

    num="$(awk -F'[<>]' '/<num>/{printf "%02d\n", $3}' "${snapshot_info}")"
    type="$(awk -F'[<>]' '/<type>/{print $3}' "${snapshot_info}")"
    date="$(awk -F'[<>]' '/<date>/{print $3}' "${snapshot_info}")"
    desc="$(awk -F'[<>]' '/<description>/{print $3}' "${snapshot_info}")"

    [ ! "${num}" -eq "${snapshot_num}" ] && err "snapshot's FS_TREE/<num=${snapshot_num}> != ${snapper_info}<num=${num}>."

    boot_conf_name="${entries_dir}/${boot_snapshot_name}-${num}-${boot_snapshot_suffix}"
    sed -E \
        -e "1i\# Generated by ${LOG_PREFIX}" \
        -e "/^title/s|$| \[#${num} ${type}\] ${date} ${desc}|" \
        -e "/^sort-key/s|$|\~${num}|" \
        -e "/^options/s|(subvol)(id)?=[^,$]+|\1=${snapshot_subvol}|" \
        "${entries_dir}/${base_conf}" \
        >"${boot_conf_name}"
}

snapshot_subvols="$(get_btrfs_snapshots)"
for sub in ${snapshot_subvols}; do
    make_conf "$sub"
done
